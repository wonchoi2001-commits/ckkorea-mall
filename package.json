{
  "name": "ckkorea-mall",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "tsc --noEmit -p tsconfig.typecheck.json",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "collect:products": "node --experimental-strip-types scripts/collect-products.ts",
    "collect:products:stage2": "node --experimental-strip-types scripts/collect-products-stage2.ts",
    "normalize:products": "node --experimental-strip-types scripts/normalize-products.ts",
    "normalize:products:stage2": "node --experimental-strip-types scripts/normalize-products-stage2.ts",
    "import:products": "node --experimental-strip-types scripts/import-products.ts",
    "import:products:stage2": "node --experimental-strip-types scripts/import-products-stage2.ts",
    "seed:products:stage4": "node --experimental-strip-types scripts/seed-products-stage4.ts",
    "import:products:stage4": "node --experimental-strip-types scripts/import-products-stage4.ts",
    "refresh:featured": "node --experimental-strip-types scripts/refresh-featured-products.ts",
    "sync:products": "npm run collect:products && npm run normalize:products && npm run import:products",
    "sync:products:stage2": "npm run collect:products:stage2 && npm run normalize:products:stage2 && npm run import:products:stage2 && npm run refresh:featured",
    "sync:products:stage4": "npm run seed:products:stage4 && npm run import:products:stage4 && npm run refresh:featured"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tosspayments/tosspayments-sdk": "^2.6.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.8",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
