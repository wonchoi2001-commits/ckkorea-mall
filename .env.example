# Public site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_PRODUCT_IMAGE_BUCKET=product-images
NEXT_PUBLIC_SUPABASE_PRODUCT_IMAGE_BUCKET=product-images

# Server-side signing secret for checkout/session protection
# Use a long random value that is different from every other secret.
APP_SIGNING_SECRET=replace-with-a-long-random-secret

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_PAYMENTS_SECRET_KEY=test_sk_...

# Admin
ADMIN_EMAILS=admin@example.com

# Notifications
QUOTE_RECEIVER_EMAIL=ops@example.com
ADMIN_NOTIFICATION_EMAILS=ops@example.com
ORDER_RECEIVER_EMAILS=ops@example.com
QUOTE_RECEIVER_EMAILS=ops@example.com
NOTIFICATION_FROM_EMAIL=CKKorea Mall <no-reply@your-domain.example>
RESEND_API_KEY=re_...
ADMIN_NOTIFICATION_WEBHOOK_URL=https://hooks.example.com/ckkorea
